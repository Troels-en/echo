# VoiceVault — copy to .env and fill in
#
# Three setup modes (pick one):
#   1. CLI mode (recommended for personal use) — uses local `codex` / `claude` CLI
#      subscriptions. No API keys, free up to subscription quota.
#   2. API mode — set OPENAI_API_KEY or ANTHROPIC_API_KEY (pay per token).
#   3. Local mode — uses Ollama for LLM. Free, offline, lower quality.

# REQUIRED — Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Vault root — where your *_Vault folders live
VAULT_ROOT=~/

# Allowed Telegram user IDs (comma-separated). Get from @userinfobot.
ALLOWED_USER_IDS=

# LLM mode: cli | api | local
LLM_MODE=cli

# CLI mode settings (used when LLM_MODE=cli)
LLM_PRIMARY=codex
LLM_FALLBACK=claude
LLM_DEEP=claude

# "ask" intent (general questions / web research via claude -p)
ASK_MODEL=sonnet
ASK_WEB_TIMEOUT=300

# API mode settings (used when LLM_MODE=api) — uncomment + fill if needed
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Whisper backend: whisper-cpp | mlx | api
WHISPER_BACKEND=whisper-cpp
WHISPER_MODEL=large-v3-turbo

# Todoist (optional) — get token from Todoist > Settings > Integrations > Developer
TODOIST_API_TOKEN=

# Embedding model (multilingual, runs locally via sentence-transformers).
# Options: paraphrase-multilingual-MiniLM-L12-v2 (fast) | multilingual-e5-base (better)
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Voice-memo replies (optional) — ElevenLabs TTS. Toggle in the bot with /voice on|off.
# Without a key, /voice still toggles but no audio is sent. Get a key at elevenlabs.io.
ELEVENLABS_API_KEY=
# Voice ID (default = Rachel, multilingual-capable). Browse voices at elevenlabs.io/app/voice-library.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Model — eleven_multilingual_v2 handles German well.
ELEVENLABS_MODEL=eleven_multilingual_v2
# Max characters synthesized; longer answers become a short spoken summary (full text stays in chat).
TTS_MAX_CHARS=600
